<div class="space-y-6">
  <h1 class="text-3xl font-bold"><%= @tenant.name %> Blog</h1>
  <% if @blogs.any? %>
    <div class="divide-y divide-gray-200" id="tenant-blogs">
      <% @blogs.each do |blog| %>
        <div class="py-4">
          <h2 class="text-xl font-semibold"><%= link_to blog.title, tenant_blog_by_id_path(id: blog.id) %></h2>
          <% if blog.description.present? %>
            <p class="text-gray-600"><%= truncate(blog.description, length: 160) %></p>
          <% end %>
          <div class="text-sm text-gray-500 mt-1">Comments: <code><%= blog.comments_setting %></code></div>

          <% latest = blog.posts.order(Arel.sql("COALESCE(published_at, created_at) DESC")).limit(5) %>
          <div class="mt-3 space-y-1" data-test-id="latest-posts">
            <% if latest.any? %>
              <% latest.each do |post| %>
                <div class="text-sm">
                  <span class="font-medium"><%= post.title %></span>
                  <% if post.published_at.present? %>
                    <span class="text-gray-500">— <%= l(post.published_at, format: :short) %></span>
                  <% end %>
                </div>
              <% end %>
            <% else %>
              <div class="text-sm text-gray-500">No posts yet</div>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="text-gray-600">No blogs yet for this tenant.</div>
  <% end %>
</div>
