<div class="mx-auto max-w-2xl py-16">
  <h1 class="text-3xl font-bold"><%= @tenant.homepage_title.presence || @tenant.name %></h1>
  <div class="prose mt-4">
    <%= simple_format(@tenant.homepage_body.presence || "This is your homepage.") %>
  </div>

  <% if @tenant.blogs.any? %>
    <div class="mt-8">
      <%= link_to "Visit blog", tenant_blog_path, class: "px-4 py-2 bg-blue-600 hover:bg-blue-500 text-white rounded-md" %>
    </div>
  <% end %>
</div>
