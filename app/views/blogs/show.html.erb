<p style="color: green"><%= notice %></p>

<div class="space-y-2">
  <h1 class="text-3xl font-bold"><%= @blog.title %></h1>
  <div class="text-gray-600">Tenant: <%= @blog.tenant.name %></div>
  <div class="text-gray-600">Comments: <code><%= @blog.comments_setting %></code></div>

  <p class="mt-4"><%= simple_format(@blog.description) %></p>
</div>

<div class="mt-5 space-x-2">
  <%= link_to "Edit this blog", edit_blog_path(@blog), class: "px-3 py-2 bg-gray-100 hover:bg-gray-50 rounded-md" %>
  <%= button_to "Destroy this blog", @blog, method: :delete, data: { confirm: "Are you sure?" }, class: "px-3 py-2 bg-red-600 hover:bg-red-500 text-white rounded-md" %>
  <%= link_to "Back to blogs", blogs_path, class: "px-3 py-2 bg-gray-100 hover:bg-gray-50 rounded-md" %>
</div>
