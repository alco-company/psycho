<%= form_with(model: blog, class: "contents") do |form| %>
  <% if blog.errors.any? %>
    <div id="error_explanation" class="bg-red-50 text-red-500 px-3 py-2 font-medium rounded-md mt-3">
      <h2><%= pluralize(blog.errors.count, "error") %> prohibited this blog from being saved:</h2>

      <ul class="list-disc ml-6">
        <% blog.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="my-5 grid grid-cols-1 md:grid-cols-2 gap-6">
    <div>
      <%= form.label :tenant_id, "Tenant" %>
      <%= form.collection_select :tenant_id, Tenant.all, :id, :name, {}, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": blog.errors[:tenant_id].none?, "border-red-400 focus:outline-red-600": blog.errors[:tenant_id].any?}] %>
    </div>
    <div>
      <%= form.label :comments_setting, "Comments" %>
      <%= form.select :comments_setting, Blog.comments_settings.keys.map { |k| [k.humanize, k] }, {}, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": blog.errors[:comments_setting].none?, "border-red-400 focus:outline-red-600": blog.errors[:comments_setting].any?}] %>
    </div>
  </div>

  <div class="my-5">
    <%= form.label :title %>
    <%= form.text_field :title, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": blog.errors[:title].none?, "border-red-400 focus:outline-red-600": blog.errors[:title].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :description %>
    <%= form.text_area :description, rows: 6, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": blog.errors[:description].none?, "border-red-400 focus:outline-red-600": blog.errors[:description].any?}] %>
  </div>

  <div class="inline">
    <%= form.submit class: "w-full sm:w-auto rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white inline-block font-medium cursor-pointer" %>
  </div>
<% end %>
