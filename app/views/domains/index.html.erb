<p style="color: green"><%= notice %></p>

<h1>Domains</h1>

<div id="domains">
  <table class="min-w-full">
    <thead>
      <tr>
        <th class="text-left p-2">Host</th>
        <th class="text-left p-2">Tenant</th>
        <th class="text-left p-2"></th>
      </tr>
    </thead>
    <tbody>
      <% @domains.each do |domain| %>
        <tr>
          <td class="p-2"><%= domain.host %></td>
          <td class="p-2"><%= link_to domain.tenant.name, domain.tenant %></td>
          <td class="p-2"><%= link_to "Show", domain %> · <%= link_to "Edit", edit_domain_path(domain) %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<p>
  <%= link_to "New domain", new_domain_path %>
</p>
